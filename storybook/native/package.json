{
  "name": "@template/example",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "storybook-generate": "sb-rn-get-stories",
    "typecheck": "bun run storybook-generate && tsc --noEmit",
    "test:native:ios": "vitest run --project ios",
    "test:native:ios:bootstrap": "vitest-mobile bootstrap --platform ios",
    "test:native:ios:bundle": "vitest-mobile bundle --platform ios",
    "test:native:android": "vitest run --project android",
    "test:native:android:setup": "./scripts/android-setup.sh",
    "test:native:android:run": "bun run test:native:android:setup && bun run test:native:android",
    "test:native:android:bootstrap": "vitest-mobile bootstrap --platform android",
    "test:native:android:bundle": "vitest-mobile bundle --platform android"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@storybook/addon-ondevice-actions": "^10.4.6",
    "@storybook/addon-ondevice-backgrounds": "^10.4.6",
    "@storybook/addon-ondevice-controls": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-native": "^10.4.6",
    "@template/ui": "workspace:*",
    "expo": "^54",
    "expo-status-bar": "3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "uniwind": "^1.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^6",
    "vitest": "^4.1.10",
    "vitest-mobile": "^0.4.3"
  }
}
