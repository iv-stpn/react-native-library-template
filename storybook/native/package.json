{
  "name": "@template/example",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "storybook-generate": "sb-rn-get-stories",
    "typecheck": "bun run storybook-generate && tsc --noEmit",
    "test:native:ios": "vitest run --project ios",
    "test:native:ios:bootstrap": "vitest-mobile bootstrap --platform ios",
    "test:native:ios:bundle": "vitest-mobile bundle --platform ios",
    "test:native:android": "vitest run --project android",
    "test:native:android:setup": "./scripts/android-setup.sh",
    "test:native:android:run": "bun run test:native:android:setup && bun run test:native:android",
    "test:native:android:bootstrap": "vitest-mobile bootstrap --platform android",
    "test:native:android:bundle": "vitest-mobile bundle --platform android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@storybook/addon-ondevice-actions": "10.5.0",
    "@storybook/addon-ondevice-backgrounds": "10.5.0",
    "@storybook/addon-ondevice-controls": "10.5.0",
    "@storybook/react": "10.5.0",
    "@storybook/react-native": "10.5.0",
    "@template/ui": "workspace:*",
    "expo": "57.0.4",
    "expo-status-bar": "57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.2",
    "storybook": "10.5.0",
    "tailwindcss": "4.3.2",
    "uniwind": "1.10.0"
  },
  "devDependencies": {
    "@types/react": "19.1.10",
    "babel-preset-expo": "57.0.2",
    "typescript": "^7",
    "vitest": "^4",
    "vitest-mobile": "0.4.3"
  }
}
