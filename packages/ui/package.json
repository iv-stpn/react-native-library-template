{
  "name": "@template/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable React Native UI component library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/react-native-library-template.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "react-native",
    "react",
    "ui",
    "components"
  ],
  "exports": {
    "./button": {
      "source": "./src/components/Button/button.tsx",
      "types": "./lib/typescript/components/Button/button.d.ts",
      "default": "./lib/module/components/Button/button.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "typecheck": "tsc --noEmit"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/*.{test,stories,d}.{ts,tsx}",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "dependencies": {
    "class-variance-authority": "0.7.1"
  },
  "devDependencies": {
    "@storybook/react": "10.5.0",
    "@types/react": "19.1.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "0.43.0",
    "react-native-web": "0.21.2",
    "storybook": "10.5.0",
    "tailwindcss": "4.3.2",
    "typescript": "^7",
    "uniwind": "1.10.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
